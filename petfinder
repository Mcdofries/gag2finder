local function dmods(o)
    local mods,hi,hr={},nil,0
    pcall(function()
        local s=o.Name:lower()
        for _,d in ipairs(o:GetDescendants()) do
            if d:IsA("TextLabel") or d:IsA("StringValue") then
                s=s.." "..(d:IsA("TextLabel") and d.Text or d.Value):lower()
            end
        end
        for mn2,md in pairs(MODS) do
            if s:find(mn2) then
                table.insert(mods,mn2)
                if md.rk>hr then hr=md.rk;hi=mn2 end
            end
        end
    end)
    return mods,hi
end

local function gpb(n)
    local r=n:gsub("^WildPet_","")
    local p=r:match("^(.-)_WildPet_")
    if not p then return nil end
    for m in pairs(MODS) do
        p=p:gsub("^"..m:sub(1,1):upper()..m:sub(2).."_","")
        p=p:gsub("^"..m.."_","")
    end
    p=p:gsub("^Mythical_","")
    p=p:gsub("^mythical_","")
    local d=PETS[p]
    if d then return d.d or p,d end
end

local function gl(o,n)
    local ok,t=pcall(function()
        local rp=o:FindFirstChild("RootPart")
        if not rp then return "?" end
        local bb=rp:FindFirstChild(n)
        if not bb then return "?" end
        local l=bb:FindFirstChildOfClass("TextLabel")
        if l then return l.Text end
        for _,c in ipairs(bb:GetDescendants()) do
            if c:IsA("TextLabel") then return c.Text end
        end
        return "?"
    end)
    return ok and t or "?"
end

local function bi(o)
    local nm,pd=gpb(o.Name)
    if not nm then return nil end
    local mods,hm=dmods(o)
    local rk,ry,co=pd.rk,pd.r,pd.c
    if hm and MODS[hm] and MODS[hm].rk>rk then
        rk=MODS[hm].rk
        ry=MODS[hm].name
        co=MODS[hm].c
    end
    return {nm=nm,pd=pd,ry=ry,rk=rk,co=co,mods=mods,
        pr=gl(o,"PetCostTimer"),tm=gl(o,"PetLeaveTimer"),key=o.Name}
end

