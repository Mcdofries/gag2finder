    mkG();setSt("Starting...")
    setupReconnect()
    
    if not game:IsLoaded() then setSt("⏳ Loading...");game.Loaded:Wait() end
    task.wait(2)
    if _G.GAG2_STOP then return end
    
    if game.PlaceId~=PID then
        lg("Wrong game!","ERR");setSt("⚠️ Wrong game...")
        pcall(function() TS:Teleport(PID,lp) end);return
    end
    
    visited[game.JobId]=os.time()
    saveVisited()
    
    lg("Server:"..game.JobId:sub(1,12).." | Visited: "..countVisited(),"OK")
    setSt("✅ In GAG2!");cpg()
    task.spawn(function() rc(false) end)

    if not _G.GAG2_SENT_ONLINE then
        _G.GAG2_SENT_ONLINE=true
        task.spawn(function()
            wh({username="Pet Finder - Grow a Garden 2",
                content="✅ **Online!** GAG2"})
        end)
    end

    local spawns
    for i=1,20 do
        spawns=gsp()
        if spawns then break end
        task.wait(0.3)
    end
    if not spawns then
        lg("No WildPetSpawns!","ERR");setSt("⚠️ No pets...")
        dh();return
    end
    lg("Spawns:"..#spawns:GetChildren(),"OK");setSt("🔍 Scanning...")
    sa()
    spawns.ChildAdded:Connect(function(child)
        if _G.GAG2_STOP then return end
        task.wait(0.2)
        if not notif[child.Name] then hp(bi(child)) end
    end)
    local t0=tick();local ln=tick()
    while not _G.GAG2_STOP do
        task.wait(0.2)
        local n=sa()
        if n>0 then ln=tick() end
        if tick()-ln>=2 and tick()-t0>=3 then
            setSt("✅ Done! Hopping...")
            dh();return
        end
        if tick()-t0>=30 then dh();return end
    end
end

