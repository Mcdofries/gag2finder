local function gsvs(cursor)
    if not req then return nil end
    local url="https://games.roblox.com/v1/games/"..PID.."/servers/Public?sortOrder=Desc&limit=100"
    if cursor then url=url.."&cursor="..cursor end
    local ok,r=pcall(function() return req({Url=url,Method="GET"}) end)
    if not ok or not r then return nil end
    local body=r.Body or r.body or r.responseBody
    if not body then return nil end
    local s,d=pcall(function() return HS:JSONDecode(body) end)
    return s and d or nil
end

local function rc(includeVisited)
    cache={}
    local cur=nil
    local seen={}
    local total=0
    for i=1,15 do
        local d=gsvs(cur)
        if not d or not d.data then break end
        for _,sv in ipairs(d.data) do
            total=total+1
            if sv.id and sv.id~=game.JobId and not seen[sv.id]
               and sv.playing>=MINPL and sv.playing<=MAXPL
               and sv.maxPlayers and (sv.maxPlayers-sv.playing)>=2 then
                if includeVisited or not visited[sv.id] then
                    seen[sv.id]=true
                    table.insert(cache,sv)
                end
            end
        end
        cur=d.nextPageCursor
        if not cur then break end
        task.wait(0.1)
    end
    -- Shuffle
    for i=#cache,2,-1 do
        local j=math.random(i)
        cache[i],cache[j]=cache[j],cache[i]
    end
    lg("Cache: "..#cache.." (total:"..total..", visited:"..countVisited()..")","INFO")
    return #cache
end

local function doTP(jid)
    local ok=pcall(function() TS:TeleportToPlaceInstance(PID,jid,lp) end)
    if ok then return true end
    ok=pcall(function()
        local o=Instance.new("TeleportOptions")
        o.ServerInstanceId=jid
        TS:TeleportAsync(PID,{lp},o)
    end)
    return ok
end

local function dh()
    if hopping then return end
    hopping=true
    hops=hops+1
    visited[game.JobId]=os.time()
    saveVisited()
    saveSt()
    lg("=== Hop #"..hops.." ===","HOP")
    setSt("🔄 Hop #"..hops)
    qs();task.wait(0.5)
    
    -- Build initial cache (excluding visited)
    rc(false)
    
    local at=0
    local triedFallback=false
    
    while not _G.GAG2_STOP do
        at=at+1
        
        -- If cache empty, try refresh
        if #cache==0 then
            lg("Cache empty, refreshing...","INFO")
            local count=rc(false)
            
            -- If STILL empty, clear visited and include all
            if count==0 then
                lg("No fresh servers! Clearing visited list","ERR")
                visited={}
                visited[game.JobId]=os.time()  -- keep current
                saveVisited()
                rc(true)  -- include visited now
                
                -- If STILL empty, fallback to random teleport
                if #cache==0 then
                    if not triedFallback then
                        triedFallback=true
                        lg("No servers at all, random teleport","ERR")
                        pcall(function() TS:Teleport(PID,lp) end)
                        task.wait(8)
                    else
                        task.wait(5)
                    end
                end
            end
        end
        
        if #cache>0 then
            local sv2=table.remove(cache,1)
            if sv2 and sv2.id then
                visited[sv2.id]=os.time()
                saveVisited()
                
                setSt("🔄 Try "..at)
                lg(("Try#%d->%s(%d)"):format(at,sv2.id:sub(1,10),sv2.playing),"INFO")
                
                if doTP(sv2.id) then 
                    task.wait(10)
                end
                task.wait(1)
            end
        else
            task.wait(2)
        end
        
        -- Safety: after 30 attempts, force random teleport
        if at >= 30 then
            lg("30 attempts done, random teleport","ERR")
            pcall(function() TS:Teleport(PID,lp) end)
            task.wait(8)
            at=0
        end
    end
end

