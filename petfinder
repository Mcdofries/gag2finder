-- ============ UTILS ============
local function log(m,t)
    local i={INFO="ℹ️",OK="✅",ERR="❌",PET="🐾",HOP="🔄"}
    print(os.date("[%H:%M:%S]").." "..(i[t] or "📌").." "..m)
end

local function uptime()
    local e=os.time()-sessionStart
    return ("%02d:%02d:%02d"):format(e/3600,e%3600/60,e%60)
end

local function shouldPing(r)
    for _,v in ipairs(PING_ON) do
        if v==r:lower() then return true end
    end
end

local function sendWebhook(body)
    if not httpRequest then return false end
    return pcall(function()
        httpRequest({
            Url = WEBHOOK, Method = "POST",
            Headers = {["Content-Type"]="application/json"},
            Body = HttpService:JSONEncode(body)
        })
    end)
end

-- ============ PET EXTRACTION ============
local function getPetInfo(objName)
    local rest = objName:gsub("^WildPet_","")
    local petPart = rest:match("^(.-)_WildPet_")
    if not petPart then return nil end
    local data = PETS[petPart]
    if data then return data.display or petPart, data end
end

local function getLabel(petObj, bbName)
    local ok, txt = pcall(function()
        local rp = petObj:FindFirstChild("RootPart")
        if not rp then return "?" end
        local bb = rp:FindFirstChild(bbName)
        if not bb then return "?" end
        local lbl = bb:FindFirstChildOfClass("TextLabel")
        if lbl then return lbl.Text end
        for _, c in ipairs(bb:GetDescendants()) do
            if c:IsA("TextLabel") then return c.Text end
        end
        return "?"
    end)
    return ok and txt or "?"
end

local function getTraits(petObj)
    local ok, traits = pcall(function()
        for _, d in ipairs(petObj:GetDescendants()) do
            if d:IsA("StringValue") then
                local n = d.Name:lower()
                if n:find("trait") or n:find("mutation") then
                    if d.Value ~= "" then return d.Value end
                end
            end
        end
        return "None"
    end)
    return ok and traits or "None"
end

local function buildPetInfo(petObj)
    local petName, petData = getPetInfo(petObj.Name)
    if not petName then return nil end
    return {
        name = petName, data = petData,
        price = getLabel(petObj, "PetCostTimer"),
        timer = getLabel(petObj, "PetLeaveTimer"),
        traits = getTraits(petObj),
        key = petObj.Name,
    }
end

