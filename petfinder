-- ============ FAST SERVER HOPPER ============
local function getServers()
    if not httpRequest then return nil end
    local url = "https://games.roblox.com/v1/games/"..PLACE_ID.."/servers/Public?sortOrder=Desc&limit=100"
    local ok, response = pcall(function()
        return httpRequest({Url=url, Method="GET"})
    end)
    if not ok or not response then return nil end
    local body = response.Body or response.body
    if not body then return nil end
    local decoded
    pcall(function() decoded = HttpService:JSONDecode(body) end)
    return decoded
end

local function findServer()
    local data = getServers()
    if not data or not data.data then return nil end
    
    local candidates = {}
    for _, srv in ipairs(data.data) do
        if srv.id ~= game.JobId 
           and srv.playing >= MIN_PLAYERS
           and srv.playing <= MAX_PLAYERS
           and srv.maxPlayers > srv.playing then
            table.insert(candidates, srv)
        end
    end
    
    if #candidates == 0 then return nil end
    return candidates[math.random(1, math.min(#candidates, 15))].id
end

local function doHop()
    if hopping then return end
    hopping = true
    serversHopped = serversHopped + 1
    log("Hopping #"..serversHopped,"HOP")
    
    -- CRITICAL: Queue script to run after teleport
    queueScript()
    
    local attempts = 0
    while attempts < 8 do
        attempts = attempts + 1
        local targetId = findServer()
        
        local ok = pcall(function()
            if targetId then
                TeleportService:TeleportToPlaceInstance(PLACE_ID, targetId, lp)
            else
                TeleportService:Teleport(PLACE_ID, lp)
            end
        end)
        
        if ok then
            task.wait(5)
            return
        end
        
        log("Hop attempt "..attempts.." failed, retry...","ERR")
        task.wait(1.5)
        queueScript() -- re-queue in case
    end
    
    hopping = false
end

TeleportService.TeleportInitFailed:Connect(function(_,_,e)
    log("TPFail: "..tostring(e),"ERR")
    queueScript()
    task.wait(2)
    doHop()
end)

-- ============ HANDLE PET ============
local function handlePet(info)
    if not info then return end
    if notified[info.key] then return end
    if info.data.rank >= MIN_RANK then
        notified[info.key] = true
        totalFound = totalFound + 1
        log(("PET! %s [%s] | 💰%s | ⏰%s"):format(
            info.name, info.data.rarity, info.price, info.timer),"PET")
        task.spawn(function() webhookPet(info) end)
    else
        notified[info.key] = true
    end
end

-- ============ FAST SCANNER ============
local function getSpawns()
    local map = workspace:FindFirstChild("Map")
    return map and map:FindFirstChild("WildPetSpawns")
end

local function scanAll()
    local spawns = getSpawns()
    if not spawns then return end
    for _, petObj in ipairs(spawns:GetChildren()) do
        if not notified[petObj.Name] then
            local info = buildPetInfo(petObj)
            if info then handlePet(info) end
        end
    end
end

-- ============ MAIN ============
local function main()
    log("=== GAG2 Pet Finder ULTRA ===","INFO")
    log("Scan duration: "..SCAN_DURATION.."s","INFO")
    
    if httpRequest then log("HTTP OK","OK") else log("NO HTTP","ERR") end
    
    -- Queue immediately (in case we just teleported in)
    queueScript()
    
    if not game:IsLoaded() then game.Loaded:Wait() end
    task.wait(3) -- minimal wait
    
    log("Server: "..game.JobId.." | "..#Players:GetPlayers().." players","OK")

    -- Initial webhook
    task.spawn(function()
        sendWebhook({
            username="Pet Finder - Grow a Garden 2",
            content="✅ **Online!** Server: `"..game.JobId:sub(1,12).."` ("..#Players:GetPlayers().." players)"
        })
    end)

    -- Wait for spawns folder (max 5s)
    local spawns
    for i = 1, 10 do
        spawns = getSpawns()
        if spawns then break end
        task.wait(0.5)
    end
    
    if spawns then
        log("Found WildPetSpawns ("..#spawns:GetChildren().." pets)","OK")
        
        -- Scan existing pets IMMEDIATELY
        scanAll()
        
        -- Listen for new spawns (instant detection)
        spawns.ChildAdded:Connect(function(child)
            task.wait(0.3)
            if not notified[child.Name] then
                handlePet(buildPetInfo(child))
            end
        end)
    else
        log("No WildPetSpawns! Hopping...","ERR")
        doHop()
        return
    end

    -- Fast scan loop + hop timer
    local timer = 0
    while true do
        task.wait(0.3) -- ultra fast scan tick
        timer = timer + 0.3
        scanAll()
        
        if timer >= SCAN_DURATION then
            doHop()
            return -- exit, autoexec will restart
        end
    end
end

local function safeStart()
    local ok,err = pcall(main)
    if not ok then
        log("CRASH: "..tostring(err),"ERR")
        queueScript()
        task.wait(3)
        safeStart()
    end
end

safeStart()
