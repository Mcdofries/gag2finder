    apg(info.nm,info.ry,info.co)
    if info.rk>=MRK then
        fnd=fnd+1;saveSt()
        lg(("PET! %s[%s]"):format(info.nm,info.ry),"PET")
        task.spawn(function() whp(info) end)
    end
end

local function sa()
    local sp2=gsp()
    if not sp2 then return 0 end
    local c=0
    for _,o in ipairs(sp2:GetChildren()) do
        if not notif[o.Name] then
            local info=bi(o)
            if info then hp(info);c=c+1 end
        end
    end
    return c
end

